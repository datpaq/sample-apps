{
  "schema_version": "1.0",
  "name_for_human": "DATPAQ IP Intelligence API Sample",
  "name_for_model": "datpaq_ip_intelligence_sample",
  "description_for_human": "Interactive sample app for querying DATPAQ IP intelligence data.",
  "description_for_model": "Use this app to demonstrate GET /v1/ip-intelligence with required ip query parameter and x-api-key header. The app renders loading, empty, error, and success states and exposes copyable request URL and full JSON response.",
  "provider": {
    "name": "DATPAQ",
    "url": "https://www.datpaq.com"
  },
  "documentation_url": "https://datpaq.com/api/v1/ip-intelligence",
  "api": {
    "base_url": "https://datpaq.com/api",
    "route": "/v1/ip-intelligence",
    "method": "GET",
    "authentication": {
      "type": "api_key",
      "header": "x-api-key"
    },
    "query_parameters": [
      {
        "name": "ip",
        "required": true,
        "type": "string",
        "examples": [
          "108.44.168.128",
          "8.8.8.8",
          "2001:4860:4860::8888"
        ]
      }
    ]
  },
  "response_fields": [
    "data.ip",
    "data.network",
    "data.country",
    "data.region",
    "data.city",
    "data.asn",
    "data.org",
    "data.threat_intelligence.is_malicious",
    "data.threat_intelligence.threat_score",
    "data.threat_intelligence.is_vpn",
    "data.threat_intelligence.is_tor",
    "data.threat_intelligence.source_type"
  ]
}
